# ── Database ────────────────────────────────────────────────────────────────
# Runtime connection — MUST be the non-superuser app role so RLS is enforced.
DATABASE_URL=postgres://lumora_app:lumora_app_password@localhost:5432/lumora
# Admin connection — schema owner; used by migrations/seeds only.
DATABASE_URL_ADMIN=postgres://lumora:lumora@localhost:5432/lumora
DATABASE_SSL=false

# ── Auth (Keycloak) ─────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=lumora
JWT_ISSUER=http://localhost:8080/realms/lumora
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# ── API ─────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3000
NODE_ENV=development

# ── Payments (leave empty in dev → adapters run in stub mode) ───────────────
# Webhooks fail CLOSED without a secret. To accept UNSIGNED callbacks in local
# dev only, set NODE_ENV=development AND the flag below. Never set in prod.
ALLOW_UNSIGNED_WEBHOOKS=false
SELCOM_API_KEY=
SELCOM_API_SECRET=
GEPG_SP_CODE=
GEPG_WEBHOOK_SECRET=
BANK_API_KEY=
NMB_WEBHOOK_SECRET=
CRDB_WEBHOOK_SECRET=
VFMS_API_KEY=

# ── Comms ───────────────────────────────────────────────────────────────────
BEEM_API_KEY=
BEEM_SECRET_KEY=
SES_REGION=af-south-1
SES_FROM_ADDRESS=noreply@lumora.app

# ── AI Gateway (vLLM, optional in dev) ──────────────────────────────────────
AI_GATEWAY_URL=
AI_SMALL_MODEL=llama-3.2-3b
AI_LARGE_MODEL=llama-3.3-70b
